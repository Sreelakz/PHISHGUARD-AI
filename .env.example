# ========== API Keys ==========
# Get from: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=your_new_key
SAFE_BROWSING_ENABLED=true

# Get from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_new_key
VIRUSTOTAL_ENABLED=true
VIRUSTOTAL_CONFIDENCE_THRESHOLD=0.7

# ========== Backend ==========
BACKEND_URL=http://localhost:8000
BACKEND_PORT=8000

# ========== Database ==========
DB_PATH=database/phishing.db
